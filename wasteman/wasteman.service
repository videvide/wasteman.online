[Unit]
Description=Wasteman

[Service]
User=admin
Group=admin
# Set this to give access to all the django env variables...
EnvironmentFile=/home/admin/wasteman.online/.dummy.env
ExecStart=/home/admin/wasteman.online/.venv/bin/gunicorn -w 4 -b 127.0.0.1:1212 wasteman.wsgi.application 

[Install]
WantedBy=multi-user.target